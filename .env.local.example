# ---------------------------------------------------------------------------
# Decanted — Environment Variables
# Copy this file to .env.local and fill in the values.
# ---------------------------------------------------------------------------

# ── LLM Provider (choose ONE) ──────────────────────────────────────────────
# Setting either key automatically switches the app from mock data to live LLM.
# If both are set, OpenAI takes priority.

# OpenAI GPT-4o
OPENAI_API_KEY=

# Anthropic Claude (claude-opus-4-7)
ANTHROPIC_API_KEY=

# ── Deployment ─────────────────────────────────────────────────────────────
# Your production URL — used for origin validation in middleware.
# Example: https://decanted.vercel.app
NEXT_PUBLIC_APP_URL=
